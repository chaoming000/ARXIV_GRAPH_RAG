# Neo4j
NEO4J_URI=bolt://172.28.123.0:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=all-in-rag
NEO4J_DATABASE=neo4j

# Milvus
MILVUS_HOST=172.28.123.0
MILVUS_PORT=19530
MILVUS_COLLECTION=arxiv_paper_chunks

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
GEN_TEMPERATURE=0.2
GEN_MAX_TOKENS=1200
MAX_REFERENCE_ITEMS=3

# arXiv source
ARXIV_ENDPOINT=http://export.arxiv.org/api/query
ARXIV_SEARCH_QUERY=(cat:cs.AI OR cat:cs.CL OR cat:cs.LG OR cat:cs.CV)
ARXIV_MAX_RESULTS=250
ARXIV_PAGE_SIZE=100
ARXIV_REQUEST_DELAY_SEC=3.2

# Retrieval
FINAL_TOP_K=8
ROUTER_LLM_ENABLED=true
ROUTER_LLM_MODEL=deepseek-chat

# Runtime
CACHE_PATH=data/arxiv_papers.json
SOURCE_TAG=arxiv_recent_ai
CHUNK_SIZE=1000
CHUNK_OVERLAP=120
APP_LOG_LEVEL=WARNING
SHOW_ROUTE=false
STREAM_ANSWER=true
